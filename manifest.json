{
  "manifest_version": 3,
  "name": "YouTube Screenshot Capture",
  "version": "1.0.0",
  "description": "Capture screenshots from YouTube videos at the current playback position",
  "permissions": ["activeTab", "scripting", "downloads"],
  "host_permissions": ["*://www.youtube.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
